    <worksheet name='Hired by Year'>
      <table>
        <view>
          <datasources>
            <datasource caption='dataset' name='federated.0yob5cm1xo00br10v5j7d03hux97' />
          </datasources>
          <datasource-dependencies datasource='federated.0yob5cm1xo00br10v5j7d03hux97'>
            <column datatype='date' name='[Birthdate]' role='dimension' type='ordinal' />
            <column caption='% Total Hired' datatype='real' default-format='p0%' name='[Calculation1]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Nr. Active Employees (copy)_0565766959542272] / TOTAL([Nr. Active Employees (copy)_0565766959542272])'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Location' datatype='string' name='[Calculation_0565766967013379]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &quot;New York&quot; THEN &quot;HQ&quot;&#13;&#10;    ELSE &quot;Branch&quot;&#13;&#10;END' />
            </column>
            <column caption='Age' datatype='integer' name='[Calculation_0565766975242249]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&quot;year&quot;, [Birthdate], TODAY())' />
            </column>
            <column caption='Age Group' datatype='string' name='[Calculation_0565766976552970]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_0565766975242249] &lt; 25 THEN &apos;&gt;25&apos;&#13;&#10;ELSEIF [Calculation_0565766975242249] &gt;=25 AND [Calculation_0565766975242249] &lt; 35 THEN &apos;25-34&apos;&#13;&#10;ELSEIF [Calculation_0565766975242249] &gt;=35 AND [Calculation_0565766975242249] &lt; 45 THEN &apos;35-44&apos;&#13;&#10;ELSEIF [Calculation_0565766975242249] &gt;=45 AND [Calculation_0565766975242249] &lt; 55 THEN &apos;45-54&apos;&#13;&#10;ELSE &apos;55+&apos;&#13;&#10;END' />
            </column>
            <column caption='Status' datatype='string' name='[Calculation_0983581678112768]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Termdate]) THEN &quot;Hired&quot; &#13;&#10;ELSE &quot;Terminated&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Department]' role='dimension' type='nominal' />
            <column datatype='string' name='[Education Level]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;High School&quot;' value='H-Sch' />
              </aliases>
            </column>
            <column caption='Employee ID' datatype='string' name='[Employee_ID]' role='dimension' type='nominal' />
            <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
            <column datatype='date' name='[Hiredate]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Job Title]' role='dimension' type='nominal' />
            <column caption='Total Hired' datatype='integer' name='[Nr. Active Employees (copy)_0565766959542272]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Employee_ID])' />
            </column>
            <column datatype='string' name='[Performance Rating]' role='dimension' type='nominal' />
            <column datatype='string' name='[State]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column datatype='date' name='[Termdate]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_0565766967013379]' derivation='None' name='[none:Calculation_0565766967013379:nk]' pivot='key' type='nominal' />
